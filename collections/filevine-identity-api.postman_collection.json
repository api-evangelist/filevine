                  "key": "grant_type",
                  "value": "<string>",
                  "description": "(Required) "
                },
                {
                  "disabled": false,
                  "key": "token",
                  "value": "<string>",
                  "description": "(Required) The Personal Access Token issued from the Filevine UI."
                },
                {
                  "disabled": false,
                  "key": "scope",
                  "value": "<string>",
                  "description": "(Required) Space-separated list of requested scopes (e.g. `fv.api.gateway.access filevine.v2.api.*`)."
