{
  "opencollection": "1.0.0",
  "info": {
    "name": "Filevine Contacts API",
    "version": "2.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Contacts",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Filevine List Contacts",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.filevine.io/core/contacts",
            "params": [
              {
                "name": "offset",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "q",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List contacts in the organization with optional filters."
        },
        {
          "info": {
            "name": "Filevine Create Contact",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.filevine.io/core/contacts",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new contact card in the organization."
        },
        {
          "info": {
            "name": "Filevine Get Contact",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.filevine.io/core/contacts/:contactId",
            "params": [
              {
                "name": "contactId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieve a contact card by ID."
        },
        {
          "info": {
            "name": "Filevine Attach Project Contact",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.filevine.io/core/projects/:projectId/contacts",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Attach a contact card to a project with an optional role (e.g. opposing party, witness, adjuster)."
        }
      ]
    }
  ],
  "bundled": true
}