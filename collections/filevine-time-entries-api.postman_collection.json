  "info": {
    "_postman_id": "065b7347-66ab-4a81-9e62-759c211b0a77",
    "name": "Filevine Time Entries API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Time Entries API records billable and non-billable time against a project, including the timer-driven entries captured by Filevine's context-aware timer. Entries carry a user, a project, a duration, an optional billing rate, and a narrative description. They feed invoice generation and staff productivity reports.\n\n\nContact Support:\n Name: Filevine API Support",
      "type": "text/plain"
    }
  }
