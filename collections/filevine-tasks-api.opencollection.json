{
  "opencollection": "1.0.0",
  "info": {
    "name": "Filevine Tasks API",
    "version": "2.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Tasks",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Filevine List Project Tasks",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.filevine.io/core/projects/:projectId/tasks",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path"
              },
              {
                "name": "assigneeId",
                "value": "",
                "type": "query"
              },
              {
                "name": "status",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List tasks on a project filtered by assignee, status, and due date."
        },
        {
          "info": {
            "name": "Filevine Create Task",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.filevine.io/core/projects/:projectId/tasks",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a task on a project and assign it to a user."
        },
        {
          "info": {
            "name": "Filevine Update Task",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://api.filevine.io/core/tasks/:taskId",
            "params": [
              {
                "name": "taskId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Update a task status, due date, assignee, or priority."
        }
      ]
    }
  ],
  "bundled": true
}