{
  "opencollection": "1.0.0",
  "info": {
    "name": "Filevine Deadlines API",
    "version": "2.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Deadlines",
        "type": "folder"
      },
      "items": [
        {
          "info": {
