  "info": {
    "_postman_id": "1bcc1653-44f7-4bc3-bd56-4d80a734f8a7",
    "name": "Filevine Notes API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Notes (Activities) capture the running narrative on a Filevine project — typed memos, phone-call logs, portal messages, mentions, and internal comments. The Notes API lets external systems append notes, edit notes, pin/unpin notes, and read the project activity stream.\n\n\nContact Support:\n Name: Filevine API Support",
      "type": "text/plain"
    }
