  "info": {
    "_postman_id": "ed90d27d-b658-4426-be00-cc24c2c62702",
    "name": "Filevine Deadlines API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Deadlines API manages the date-driven legal milestones on a project — statutes of limitations, court dates, response deadlines, and reminders. Deadlines can chain (a parent deadline drives child deadlines), can be assigned to a user, and can fire notification reminders.\n\n\nContact Support:\n Name: Filevine API Support",
      "type": "text/plain"
    }
