              },
              {
                "name": "projectId",
                "value": "",
                "type": "query"
              },
              {
                "name": "from",
                "value": "",
                "type": "query"
              },
              {
                "name": "to",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "List time entries across the organization, filtered by user, project, and date range."
        },
        {
          "info": {
            "name": "Filevine Create Time Entry",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.filevine.io/core/time-entries",
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Record a new time entry against a project."
