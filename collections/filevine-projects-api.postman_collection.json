  "info": {
    "_postman_id": "5a5a09a0-c826-4ed0-bfff-469b06a9f135",
    "name": "Filevine Projects API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Projects (also called Matters) are the central organizing unit in Filevine. Each project belongs to a project type, has a primary client contact card, a phase/stage, and a customizable set of sections and fields. The Projects API lets external systems list, create, read, and update projects programmatically across an organization.\n\n\nContact Support:\n Name: Filevine API Support",
      "type": "text/plain"
    }
  }
