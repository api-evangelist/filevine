  "info": {
    "_postman_id": "a5d38b20-c1a2-4d46-beb5-ba6d13103a99",
    "name": "Filevine Webhooks API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Webhooks API lets organizations subscribe an external endpoint to Filevine events. A subscription has a name, description, endpoint URL, and a curated set of event toggles. Each subscription receives a unique signing key. Events fire when matching activity occurs in Filevine — project create/update, document upload, note create, payment created, and more.\n\n\nContact Support:\n Name: Filevine API Support",
      "type": "text/plain"
    }
  }
