{
  "opencollection": "1.0.0",
  "info": {
    "name": "Filevine Notes API",
    "version": "2.0"
  },
  "request": {
    "auth": {
      "type": "bearer",
      "token": "{{bearerToken}}"
    }
  },
  "items": [
    {
      "info": {
        "name": "Notes",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Filevine List Project Notes",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.filevine.io/core/projects/:projectId/notes",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path"
              },
              {
                "name": "offset",
                "value": "",
                "type": "query"
              },
              {
                "name": "limit",
                "value": "",
                "type": "query"
              },
              {
                "name": "since",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Read the project's note/activity stream with optional pagination and date filtering."
        },
        {
          "info": {
            "name": "Filevine Create Note",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://api.filevine.io/core/projects/:projectId/notes",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create a new note on a project. Note bodies support mentions, attached documents, and a typed kind (note, task, portal message, phone call, text)."
        },
        {
          "info": {
            "name": "Filevine Update Note",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "https://api.filevine.io/core/notes/:noteId",
            "params": [
              {
                "name": "noteId",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Edit the body or pinned state of an existing note."
        }
      ]
    }
  ],
  "bundled": true
}